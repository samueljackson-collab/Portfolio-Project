# -*- mode: ruby -*-
# vi: set ft=ruby :

MACHINES = {
  "ubuntu-22" => {
    box: "ubuntu/jammy64",
    ip: "192.168.56.10",
    memory: 2048,
    cpus: 2,
    script: "scripts/provision-ubuntu.sh"
  },
  "kali-2024" => {
    box: "kalilinux/rolling",
    ip: "192.168.56.20",
    memory: 4096,
    cpus: 2,
    script: "scripts/provision-kali.sh"
  },
  "debian-12" => {
    box: "debian/bookworm64",
    ip: "192.168.56.30",
    memory: 1024,
    cpus: 1,
    script: "scripts/provision-debian.sh"
  }
}

Vagrant.configure("2") do |config|
  MACHINES.each do |name, cfg|
    config.vm.define name do |node|
      node.vm.box = cfg[:box]
      node.vm.hostname = name
      node.vm.network "private_network", ip: cfg[:ip]
      node.vm.provider "virtualbox" do |vb|
        vb.memory = cfg[:memory]
        vb.cpus = cfg[:cpus]
        vb.name = "portfolio-lab-#{name}"
      end
      node.vm.provision "shell", path: cfg[:script]
      node.vm.provision "ansible" do |ansible|
        ansible.playbook = "ansible/site.yml"
        ansible.extra_vars = { os_type: name }
      end
    end
  end
end
